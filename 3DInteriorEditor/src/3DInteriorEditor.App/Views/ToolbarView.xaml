<UserControl x:Class="_3DInteriorEditor.App.Views.ToolbarView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
               xmlns:vm="clr-namespace:_3DInteriorEditor.App.ViewModels"
               mc:Ignorable="d"
               d:DesignHeight="48"
               d:DesignWidth="1280">

  <materialDesign:ColorZone Mode="PrimaryMid"
                             Padding="8,0"
                             materialDesign:ElevationAssist.Elevation="Dp2"
                             Background="{DynamicResource App.PanelBrush}">
    <DockPanel LastChildFill="True">

      <!-- Primary actions -->
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding NewLayoutCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Neu (Strg+N)">
          <StackPanel Orientation="Horizontal">
            <materialDesign:PackIcon Kind="FileOutline" VerticalAlignment="Center" />
            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Neu" />
          </StackPanel>
        </Button>

        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding OpenLayoutCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Öffnen (Strg+O)">
          <StackPanel Orientation="Horizontal">
            <materialDesign:PackIcon Kind="FolderOpenOutline" VerticalAlignment="Center" />
            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Öffnen" />
          </StackPanel>
        </Button>

        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding SaveLayoutCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Speichern (Strg+S)">
          <StackPanel Orientation="Horizontal">
            <materialDesign:PackIcon Kind="ContentSaveOutline" VerticalAlignment="Center" />
            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Speichern" />
          </StackPanel>
        </Button>

        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding SaveLayoutAsCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Speichern unter (Strg+Shift+S)">
          <StackPanel Orientation="Horizontal">
            <materialDesign:PackIcon Kind="ContentSaveMoveOutline" VerticalAlignment="Center" />
            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Speichern unter" />
          </StackPanel>
        </Button>

        <Rectangle Width="1"
                   Height="28"
                   Margin="10,0,12,0"
                   VerticalAlignment="Center"
                   Fill="{DynamicResource App.BorderBrush}" />

        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding UndoCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Rückgängig (Strg+Z)">
          <materialDesign:PackIcon Kind="UndoVariant" VerticalAlignment="Center" />
        </Button>

        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding RedoCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Wiederholen (Strg+Y)">
          <materialDesign:PackIcon Kind="RedoVariant" VerticalAlignment="Center" />
        </Button>

        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding DuplicateSelectedCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Duplizieren (Strg+D)">
          <materialDesign:PackIcon Kind="ContentDuplicate" VerticalAlignment="Center" />
        </Button>

        <Button Style="{DynamicResource MaterialDesignFlatButton}"
                Command="{Binding DeleteSelectedCommand}"
                Margin="0,0,8,0"
                MinHeight="44"
                ToolTip="Löschen (Entf)">
          <materialDesign:PackIcon Kind="TrashCanOutline" VerticalAlignment="Center" />
        </Button>

        <Rectangle Width="1"
                   Height="28"
                   Margin="10,0,12,0"
                   VerticalAlignment="Center"
                   Fill="{DynamicResource App.BorderBrush}" />

        <!-- Phase 20: transform tool (viewport Shift/Alt/Ctrl+Shift drags follow this mode) -->
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,4,0">
          <TextBlock VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     FontSize="11"
                     Foreground="{DynamicResource App.TextSecondaryBrush}"
                     Text="Transform" />
          <StackPanel Orientation="Horizontal">
            <Button MinHeight="40"
                    MinWidth="40"
                    Margin="0,0,4,0"
                    Padding="8,4"
                    ToolTip="Verschieben — Shift+Drag (XZ)"
                    Command="{Binding SetTransformToolCommand}">
              <Button.CommandParameter>
                <x:Static Member="vm:TransformMode.Translate" />
              </Button.CommandParameter>
              <Button.Style>
                <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                  <Setter Property="BorderThickness" Value="2" />
                  <Setter Property="BorderBrush" Value="Transparent" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsTransformTranslateActive}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource App.AccentBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <materialDesign:PackIcon Kind="CursorMove" VerticalAlignment="Center" />
            </Button>
            <Button MinHeight="40"
                    MinWidth="40"
                    Margin="0,0,4,0"
                    Padding="8,4"
                    ToolTip="Drehen — Alt+Drag (Yaw)"
                    Command="{Binding SetTransformToolCommand}">
              <Button.CommandParameter>
                <x:Static Member="vm:TransformMode.Rotate" />
              </Button.CommandParameter>
              <Button.Style>
                <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                  <Setter Property="BorderThickness" Value="2" />
                  <Setter Property="BorderBrush" Value="Transparent" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsTransformRotateActive}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource App.AccentBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <materialDesign:PackIcon Kind="RotateRight" VerticalAlignment="Center" />
            </Button>
            <Button MinHeight="40"
                    MinWidth="40"
                    Padding="8,4"
                    ToolTip="Skalieren — Strg+Umschalt+Drag"
                    Command="{Binding SetTransformToolCommand}">
              <Button.CommandParameter>
                <x:Static Member="vm:TransformMode.Scale" />
              </Button.CommandParameter>
              <Button.Style>
                <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                  <Setter Property="BorderThickness" Value="2" />
                  <Setter Property="BorderBrush" Value="Transparent" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsTransformScaleActive}" Value="True">
                      <Setter Property="BorderBrush" Value="{DynamicResource App.AccentBrush}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
              <materialDesign:PackIcon Kind="Resize" VerticalAlignment="Center" />
            </Button>
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <!-- Mode badge -->
      <Border DockPanel.Dock="Right"
              Margin="12,6"
              Padding="10,4"
              CornerRadius="6"
              Background="{DynamicResource App.ElevatedBrush}">
        <TextBlock VerticalAlignment="Center"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                   Text="{Binding ModeLabel}" />
      </Border>

    </DockPanel>
  </materialDesign:ColorZone>
</UserControl>
