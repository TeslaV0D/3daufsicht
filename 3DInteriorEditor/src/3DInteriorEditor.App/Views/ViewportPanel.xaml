<UserControl x:Class="_3DInteriorEditor.App.Views.ViewportPanel"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:h="http://helix-toolkit.org/wpf"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               d:DesignHeight="600"
               d:DesignWidth="800">

  <!-- Phase 7: HelixToolkit hosts orbit / pan / zoom on this viewport (see HelixViewport3D defaults). -->
  <Grid ClipToBounds="True">
    <h:HelixViewport3D x:Name="Viewport"
                       Background="{DynamicResource App.BackgroundBrush}"
                       ZoomExtentsWhenLoaded="True"
                       RotateAroundMouseDownPoint="True"
                       PreviewMouseLeftButtonDown="Viewport_OnPreviewMouseLeftButtonDown">

      <!-- Y-up scene: floor lies in XZ at y = 0 -->
      <h:HelixViewport3D.DefaultCamera>
        <PerspectiveCamera Position="14,11,14"
                           LookDirection="-14,-11,-14"
                           UpDirection="0,1,0"
                           FieldOfView="55"
                           NearPlaneDistance="0.05"
                           FarPlaneDistance="500" />
      </h:HelixViewport3D.DefaultCamera>

      <h:SunLight />

      <!-- Reference grid on the ground plane (XZ) -->
      <h:GridLinesVisual3D Width="48"
                           Length="48"
                           MajorDistance="2"
                           MinorDistance="0.5"
                           Thickness="0.012">
        <h:GridLinesVisual3D.Transform>
          <RotateTransform3D>
            <RotateTransform3D.Rotation>
              <AxisAngleRotation3D Axis="1,0,0" Angle="-90" />
            </RotateTransform3D.Rotation>
          </RotateTransform3D>
        </h:GridLinesVisual3D.Transform>
      </h:GridLinesVisual3D>

      <!-- Subtle ground plate for depth perception -->
      <h:BoxVisual3D Center="0,-0.005,0"
                     Length="50"
                     Width="0.01"
                     Height="50"
                     Material="{x:Static h:Materials.Gray}" />

      <h:CoordinateSystemVisual3D ArrowLengths="2" />

    </h:HelixViewport3D>

    <!-- Interaction legend (viewport interaction is viewport-local, not routed commands) -->
    <Border VerticalAlignment="Bottom"
            HorizontalAlignment="Left"
            Margin="10"
            Padding="10,6"
            CornerRadius="6"
            Background="{DynamicResource App.ElevatedBrush}">
      <Border.Effect>
        <DropShadowEffect BlurRadius="12"
                          ShadowDepth="2"
                          Opacity="0.35"
                          Color="#000000" />
      </Border.Effect>
      <TextBlock FontSize="11"
                 Foreground="{DynamicResource App.TextSecondaryBrush}">
        <Run Text="Orbit/Pan/Zoom · Strg+Klick: Select · Pfeile: Move · Shift+Pfeile: Fine · Q/E: Rotate · Shift+Q/E: Fine · Strg+D: Duplicate · Entf: Delete" />
      </TextBlock>
    </Border>
  </Grid>
</UserControl>
