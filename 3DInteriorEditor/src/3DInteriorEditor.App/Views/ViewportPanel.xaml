<UserControl x:Class="_3DInteriorEditor.App.Views.ViewportPanel"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:h="http://helix-toolkit.org/wpf"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               d:DesignHeight="600"
               d:DesignWidth="800">

  <Grid ClipToBounds="True">
    <h:HelixViewport3D x:Name="Viewport"
                       Background="{DynamicResource App.BackgroundBrush}"
                       ZoomExtentsWhenLoaded="True"
                       RotateAroundMouseDownPoint="True"
                       PreviewMouseLeftButtonDown="Viewport_OnPreviewMouseLeftButtonDown"
                       PreviewMouseMove="Viewport_OnPreviewMouseMove"
                       PreviewMouseLeftButtonUp="Viewport_OnPreviewMouseLeftButtonUp"
                       PreviewMouseRightButtonDown="Viewport_OnPreviewMouseRightButtonDown"
                       LostMouseCapture="Viewport_OnLostMouseCapture">

      <h:HelixViewport3D.DefaultCamera>
        <PerspectiveCamera Position="14,11,14"
                           LookDirection="-14,-11,-14"
                           UpDirection="0,1,0"
                           FieldOfView="55"
                           NearPlaneDistance="0.05"
                           FarPlaneDistance="500" />
      </h:HelixViewport3D.DefaultCamera>

      <h:SunLight />

      <h:GridLinesVisual3D Width="48"
                           Length="48"
                           MajorDistance="2"
                           MinorDistance="0.5"
                           Thickness="0.012">
        <h:GridLinesVisual3D.Transform>
          <RotateTransform3D>
            <RotateTransform3D.Rotation>
              <AxisAngleRotation3D Axis="1,0,0" Angle="-90" />
            </RotateTransform3D.Rotation>
          </RotateTransform3D>
        </h:GridLinesVisual3D.Transform>
      </h:GridLinesVisual3D>

      <h:BoxVisual3D Center="0,-0.005,0"
                     Length="50"
                     Width="0.01"
                     Height="50"
                     Material="{x:Static h:Materials.Gray}" />

      <h:CoordinateSystemVisual3D ArrowLengths="2" />

    </h:HelixViewport3D>

    <!-- Box select overlay (hit-test only active in Box/Circle modes; see code-behind). -->
    <Canvas x:Name="InteractionOverlay"
            Background="Transparent"
            IsHitTestVisible="False"
            MouseLeftButtonDown="Overlay_OnMouseLeftButtonDown"
            MouseMove="Overlay_OnMouseMove"
            MouseLeftButtonUp="Overlay_OnMouseLeftButtonUp">
      <Rectangle x:Name="BoxSelectRectangle"
                 Stroke="#FFB74D"
                 StrokeThickness="1"
                 Fill="#33FFB74D"
                 Visibility="Collapsed"
                 Width="0"
                 Height="0" />
    </Canvas>

    <Border VerticalAlignment="Bottom"
            HorizontalAlignment="Left"
            Margin="10"
            Padding="10,6"
            CornerRadius="6"
            Background="{DynamicResource App.ElevatedBrush}">
      <Border.Effect>
        <DropShadowEffect BlurRadius="12"
                          ShadowDepth="2"
                          Opacity="0.35"
                          Color="#000000" />
      </Border.Effect>
      <TextBlock FontSize="11"
                 Foreground="{DynamicResource App.TextSecondaryBrush}">
        <Run Text="MMB/Drehen · Shift+MMB/Schwenken · Rad/Zoom · LMB/Auswahl · B Box · C Kreis · RMB/Menü · G/R/S · Esc Modus · Shift+X/Z Achse · / Isolate" />
      </TextBlock>
    </Border>
  </Grid>
</UserControl>
