<Window x:Class="_3DInteriorEditor.App.Views.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource App.PanelBrush}">
  <Border Padding="16">
    <StackPanel>
      <TextBlock FontWeight="SemiBold"
                 Margin="0,0,0,12"
                 Foreground="{DynamicResource App.TextPrimaryBrush}"
                 Text="Allgemein" />

      <CheckBox x:Name="ZoomAroundMouseCheck"
                Margin="0,0,0,8"
                Foreground="{DynamicResource App.TextPrimaryBrush}"
                Content="Zoom am Mauszeiger (Helix, Blender-ähnlich)" />

      <TextBlock Margin="0,8,0,4"
                 FontSize="12"
                 Foreground="{DynamicResource App.TextSecondaryBrush}"
                 Text="UI-Skalierung (100 % = 1,0)" />
      <Slider x:Name="UiScaleSlider"
              Minimum="0.85"
              Maximum="1.35"
              TickFrequency="0.05"
              IsSnapToTickEnabled="False"
              Margin="0,0,0,4" />
      <TextBlock x:Name="UiScaleLabel"
                 FontSize="11"
                 Foreground="{DynamicResource App.TextSecondaryBrush}"
                 Margin="0,0,0,16" />

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button MinWidth="88"
                Margin="0,0,8,0"
                IsCancel="True"
                Content="Abbrechen" />
        <Button MinWidth="88"
                IsDefault="True"
                Content="OK"
                Click="Ok_OnClick" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
