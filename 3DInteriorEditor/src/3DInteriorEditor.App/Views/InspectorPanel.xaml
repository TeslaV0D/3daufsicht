<UserControl x:Class="_3DInteriorEditor.App.Views.InspectorPanel"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
               xmlns:helpers="clr-namespace:_3DInteriorEditor.App.Helpers"
               xmlns:viewModels="clr-namespace:_3DInteriorEditor.App.ViewModels"
               mc:Ignorable="d"
               d:DesignWidth="280">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <helpers:HexStringToColorConverter x:Key="HexStringToColorConverter" />
  </UserControl.Resources>

  <DockPanel Background="{DynamicResource App.PanelBrush}">
    <Border DockPanel.Dock="Top" Padding="12,12,12,10">
      <DockPanel LastChildFill="True">
        <materialDesign:PackIcon DockPanel.Dock="Left"
                                 Kind="Tune"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource App.AccentBrush}" />
        <StackPanel>
          <TextBlock FontWeight="SemiBold"
                     Text="{Binding Inspector.HeaderText}" />
          <TextBlock Margin="0,4,0,0"
                     FontSize="12"
                     Foreground="{DynamicResource App.TextSecondaryBrush}"
                     Text="Strg+Klick im Viewport: Auswahl (Toggle)" />
        </StackPanel>
      </DockPanel>
    </Border>

    <ScrollViewer Padding="12,0,12,12" VerticalScrollBarVisibility="Auto">
      <materialDesign:Card Padding="12"
                           materialDesign:ElevationAssist.Elevation="Dp1">
        <StackPanel>
          <TextBlock FontSize="13"
                     Foreground="{DynamicResource App.TextSecondaryBrush}">
            Ausgewählt:
            <Run Text="{Binding Inspector.SelectedCount, Mode=OneWay}" />
          </TextBlock>

          <Separator Margin="0,12,0,12"
                     Background="{DynamicResource App.BorderBrush}" />

          <!-- Phase 13: editable transform when exactly one asset is selected -->
          <Border Margin="0,0,0,12"
                  Padding="10"
                  CornerRadius="10"
                  Background="{DynamicResource App.ElevatedBrush}"
                  Visibility="{Binding IsInspectorTransformVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Margin="0,0,0,10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource App.TextPrimaryBrush}"
                         Text="Transform (m / °)" />

              <TextBlock Margin="0,0,0,4"
                         FontSize="11"
                         Foreground="{DynamicResource App.TextSecondaryBrush}"
                         Text="Position (m), Dezimalpunkt" />

              <UniformGrid Columns="3" Margin="0,0,0,8">
                <TextBox Margin="0,0,6,0"
                         materialDesign:HintAssist.Hint="X"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorPosXText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Margin="0,0,6,0"
                         materialDesign:HintAssist.Hint="Y"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorPosYText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox materialDesign:HintAssist.Hint="Z"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorPosZText, UpdateSourceTrigger=PropertyChanged}" />
              </UniformGrid>

              <TextBlock Margin="0,4,0,4"
                         FontSize="11"
                         Foreground="{DynamicResource App.TextSecondaryBrush}"
                         Text="Rotation (deg), Euler X/Y/Z" />

              <UniformGrid Columns="3" Margin="0,0,0,10">
                <TextBox Margin="0,0,6,0"
                         materialDesign:HintAssist.Hint="RX"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorRotXText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Margin="0,0,6,0"
                         materialDesign:HintAssist.Hint="RY"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorRotYText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox materialDesign:HintAssist.Hint="RZ"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorRotZText, UpdateSourceTrigger=PropertyChanged}" />
              </UniformGrid>

              <UniformGrid Columns="2">
                <Button Margin="0,0,6,0"
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Command="{Binding ApplyInspectorTransformCommand}"
                        Content="Übernehmen" />
                <Button Margin="6,0,0,0"
                        Style="{DynamicResource MaterialDesignOutlinedButton}"
                        Command="{Binding ResetInspectorTransformCommand}"
                        Content="Zurücksetzen" />
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Phase 18: dimensions + color when exactly one asset is selected -->
          <Border Margin="0,0,0,12"
                  Padding="10"
                  CornerRadius="10"
                  Background="{DynamicResource App.ElevatedBrush}"
                  Visibility="{Binding IsInspectorTransformVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Margin="0,0,0,10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource App.TextPrimaryBrush}"
                         Text="Maße / Farbe" />

              <TextBlock Margin="0,0,0,4"
                         FontSize="11"
                         Foreground="{DynamicResource App.TextSecondaryBrush}"
                         Text="Abmessungen (m), Breite X · Höhe Y · Tiefe Z · Min." />

              <UniformGrid Columns="3" Margin="0,0,0,10">
                <TextBox Margin="0,0,6,0"
                         materialDesign:HintAssist.Hint="X"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorDimXText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Margin="0,0,6,0"
                         materialDesign:HintAssist.Hint="Y"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorDimYText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox materialDesign:HintAssist.Hint="Z"
                         Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding InspectorDimZText, UpdateSourceTrigger=PropertyChanged}" />
              </UniformGrid>

              <TextBlock Margin="0,0,0,4"
                         FontSize="11"
                         Foreground="{DynamicResource App.TextSecondaryBrush}"
                         Text="Farbe (#RRGGBB oder #AARRGGBB)" />

              <TextBox Margin="0,0,0,10"
                       materialDesign:HintAssist.Hint="#RRGGBB"
                       Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                       Text="{Binding InspectorColorHexText, UpdateSourceTrigger=PropertyChanged}" />

              <TextBlock Margin="0,0,0,6"
                         FontSize="11"
                         Foreground="{DynamicResource App.TextSecondaryBrush}"
                         Text="Palette (Klick)" />

              <ItemsControl ItemsSource="{Binding InspectorColorPalette}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Width="26"
                            Height="26"
                            Margin="2"
                            Padding="0"
                            Style="{DynamicResource MaterialDesignIconButton}"
                            ToolTip="{Binding}"
                            Command="{Binding DataContext.PickInspectorColorSwatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}">
                      <Border Width="18"
                              Height="18"
                              CornerRadius="3"
                              BorderBrush="{DynamicResource App.BorderBrush}"
                              BorderThickness="1">
                        <Border.Background>
                          <SolidColorBrush Color="{Binding Converter={StaticResource HexStringToColorConverter}}" />
                        </Border.Background>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <UniformGrid Margin="0,12,0,0" Columns="2">
                <Button Margin="0,0,6,0"
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Command="{Binding ApplyInspectorAppearanceCommand}"
                        Content="Übernehmen" />
                <Button Margin="6,0,0,0"
                        Style="{DynamicResource MaterialDesignOutlinedButton}"
                        Command="{Binding ResetInspectorAppearanceCommand}"
                        Content="Zurücksetzen" />
              </UniformGrid>
            </StackPanel>
          </Border>

          <!-- Phase 19: metadata (template keys + instance values) -->
          <Border Margin="0,0,0,12"
                  Padding="10"
                  CornerRadius="10"
                  Background="{DynamicResource App.ElevatedBrush}"
                  Visibility="{Binding IsInspectorTransformVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
              <TextBlock Margin="0,0,0,10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource App.TextPrimaryBrush}"
                         Text="Metadaten" />

              <TextBlock Margin="0,0,0,8"
                         FontSize="11"
                         Foreground="{DynamicResource App.TextSecondaryBrush}"
                         Text="Schlüssel aus Vorlage; zusätzliche Schlüssel aus der Instanz. Übernehmen speichert alle Werte."
                         TextWrapping="Wrap" />

              <TextBlock Margin="0,0,0,10"
                         FontSize="11"
                         Foreground="{DynamicResource App.TextSecondaryBrush}"
                         Text="Keine Metadatenfelder für diese Auswahl."
                         TextWrapping="Wrap"
                         Visibility="{Binding InspectorMetadataEmptyVisible, Converter={StaticResource BoolToVis}}" />

              <ItemsControl ItemsSource="{Binding InspectorMetadataRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type viewModels:InspectorMetadataRowViewModel}">
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="118" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="2*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0"
                                 VerticalAlignment="Center"
                                 FontSize="12"
                                 Foreground="{DynamicResource App.TextSecondaryBrush}"
                                 Text="{Binding Key}"
                                 TextTrimming="CharacterEllipsis"
                                 ToolTip="{Binding Key}" />
                      <TextBox Grid.Column="2"
                               materialDesign:HintAssist.Hint="Wert"
                               Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                               FontSize="12"
                               Text="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <UniformGrid Margin="0,4,0,0" Columns="2">
                <Button Margin="0,0,6,0"
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Command="{Binding ApplyInspectorMetadataCommand}"
                        Content="Übernehmen" />
                <Button Margin="6,0,0,0"
                        Style="{DynamicResource MaterialDesignOutlinedButton}"
                        Command="{Binding ResetInspectorMetadataCommand}"
                        Content="Zurücksetzen" />
              </UniformGrid>
            </StackPanel>
          </Border>

          <ItemsControl ItemsSource="{Binding Inspector.SelectedAssets}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,0,8"
                        Padding="10,8"
                        CornerRadius="8"
                        Background="{DynamicResource App.ElevatedBrush}">
                  <StackPanel>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource App.TextSecondaryBrush}">
                      <Run Text="ID: " />
                      <Run Text="{Binding Id}" />
                    </TextBlock>

                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource App.TextSecondaryBrush}">
                      Pos:
                      <Run Text="{Binding PositionMeters.X, StringFormat={}{0:0.##}}" />
                      <Run Text=", " />
                      <Run Text="{Binding PositionMeters.Y, StringFormat={}{0:0.##}}" />
                      <Run Text=", " />
                      <Run Text="{Binding PositionMeters.Z, StringFormat={}{0:0.##}}" />
                    </TextBlock>

                    <TextBlock Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource App.TextSecondaryBrush}">
                      Rot:
                      <Run Text="{Binding RotationDegrees.X, StringFormat={}{0:0.#}}" />
                      <Run Text=", " />
                      <Run Text="{Binding RotationDegrees.Y, StringFormat={}{0:0.#}}" />
                      <Run Text=", " />
                      <Run Text="{Binding RotationDegrees.Z, StringFormat={}{0:0.#}}" />
                    </TextBlock>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Separator Margin="0,12,0,12"
                     Background="{DynamicResource App.BorderBrush}" />

          <TextBlock FontSize="12"
                     Foreground="{DynamicResource App.TextSecondaryBrush}">
            Assets:
            <Run Text="{Binding PlacedAssets.Count, Mode=OneWay}" />
          </TextBlock>

          <TextBlock Margin="0,10,0,0"
                     FontSize="12"
                     Foreground="{DynamicResource App.TextSecondaryBrush}">
            Vorlagen im Dokument:
            <Run Text="{Binding AssetDefinitions.Count, Mode=OneWay}" />
          </TextBlock>
        </StackPanel>
      </materialDesign:Card>
    </ScrollViewer>
  </DockPanel>
</UserControl>
