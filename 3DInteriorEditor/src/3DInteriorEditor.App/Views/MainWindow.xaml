<Window x:Class="_3DInteriorEditor.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:_3DInteriorEditor.App.Views"
        Title="{Binding WindowTitle}"
        Width="1280"
        Height="800"
        MinWidth="800"
        MinHeight="600"
        Background="{DynamicResource App.BackgroundBrush}"
        TextElement.Foreground="{DynamicResource App.TextPrimaryBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

  <Window.InputBindings>
    <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewLayoutCommand}" />
    <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenLayoutCommand}" />
    <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveLayoutCommand}" />
    <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveLayoutAsCommand}" />
  </Window.InputBindings>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="48" />
      <RowDefinition Height="*" />
      <RowDefinition Height="28" />
    </Grid.RowDefinitions>

    <Menu Grid.Row="0" Background="{DynamicResource App.PanelBrush}">
      <MenuItem Header="_Datei">
        <MenuItem Header="_Neu" InputGestureText="Strg+N" Command="{Binding NewLayoutCommand}" />
        <MenuItem Header="_Öffnen…" InputGestureText="Strg+O" Command="{Binding OpenLayoutCommand}" />
        <Separator />
        <MenuItem Header="_Speichern" InputGestureText="Strg+S" Command="{Binding SaveLayoutCommand}" />
        <MenuItem Header="Speichern _unter…" InputGestureText="Strg+Umschalt+S" Command="{Binding SaveLayoutAsCommand}" />
      </MenuItem>
    </Menu>

    <views:ToolbarView Grid.Row="1" />

    <Grid Grid.Row="2" Background="{DynamicResource App.BackgroundBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="280" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              BorderBrush="{DynamicResource App.BorderBrush}"
              BorderThickness="0,0,1,0">
        <views:AssetLibraryPanel />
      </Border>

      <Border Grid.Column="1">
        <Grid>
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource App.TextSecondaryBrush}"
                     Text="Phase 6 chrome — viewport comes in Phase 7" />
        </Grid>
      </Border>

      <Border Grid.Column="2"
              BorderBrush="{DynamicResource App.BorderBrush}"
              BorderThickness="1,0,0,0">
        <views:InspectorPanel />
      </Border>
    </Grid>

    <Border Grid.Row="3" Background="{DynamicResource App.PanelBrush}">
      <DockPanel LastChildFill="True" Margin="12,0">
        <TextBlock DockPanel.Dock="Right"
                   VerticalAlignment="Center"
                   Margin="12,0,0,0"
                   FontSize="12"
                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                   Text="{Binding ModeLabel}" />

        <TextBlock VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                   Text="{Binding StatusText}" />
      </DockPanel>
    </Border>
  </Grid>
</Window>

