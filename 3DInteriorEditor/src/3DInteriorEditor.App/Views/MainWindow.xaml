<Window x:Class="_3DInteriorEditor.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:_3DInteriorEditor.App.Views"
        xmlns:vm="clr-namespace:_3DInteriorEditor.App.ViewModels"
        Title="{Binding WindowTitle}"
        Width="1320"
        Height="820"
        MinWidth="800"
        MinHeight="600"
        Background="{DynamicResource App.BackgroundBrush}"
        TextElement.Foreground="{DynamicResource App.TextPrimaryBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

  <Window.InputBindings>
    <!-- File -->
    <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewLayoutCommand}" />
    <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenLayoutCommand}" />
    <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveLayoutCommand}" />
    <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveLayoutAsCommand}" />
    <KeyBinding Key="I" Modifiers="Control+Shift" Command="{Binding ImportModelAsyncCommand}" />
    <KeyBinding Key="E" Modifiers="Control+Shift" Command="{Binding ExportLayoutJsonAsyncCommand}" />
    <KeyBinding Key="Q" Modifiers="Control" Command="{Binding QuitApplicationCommand}" />

    <!-- Edit -->
    <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
    <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}" />
    <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoCommand}" />
    <KeyBinding Key="A" Modifiers="Alt" Command="{Binding ClearSelectionMenuCommand}" />
    <KeyBinding Key="A" Command="{Binding ToggleSelectAllPlacedCommand}" />
    <KeyBinding Key="I" Modifiers="Control" Command="{Binding InvertSelectionCommand}" />
    <KeyBinding Key="Comma" Modifiers="Control" Command="{Binding ShowPreferencesDialogCommand}" />

    <!-- Blender-style transform tools -->
    <KeyBinding Key="G" Command="{Binding SetTransformToolCommand}">
      <KeyBinding.CommandParameter>
        <x:Static Member="vm:TransformMode.Translate" />
      </KeyBinding.CommandParameter>
    </KeyBinding>
    <KeyBinding Key="R" Command="{Binding SetTransformToolCommand}">
      <KeyBinding.CommandParameter>
        <x:Static Member="vm:TransformMode.Rotate" />
      </KeyBinding.CommandParameter>
    </KeyBinding>
    <KeyBinding Key="S" Command="{Binding SetTransformToolCommand}">
      <KeyBinding.CommandParameter>
        <x:Static Member="vm:TransformMode.Scale" />
      </KeyBinding.CommandParameter>
    </KeyBinding>

    <!-- Objects -->
    <KeyBinding Key="D" Modifiers="Control" Command="{Binding DuplicateSelectedCommand}" />
    <KeyBinding Key="D" Modifiers="Shift" Command="{Binding DuplicateSelectedCommand}" />
    <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
    <KeyBinding Key="X" Command="{Binding DeleteSelectedCommand}" />
    <KeyBinding Key="H" Command="{Binding HideSelectedPlacedCommand}" />
    <KeyBinding Key="H" Modifiers="Alt" Command="{Binding ShowAllPlacedCommand}" />

    <!-- Legacy nudge / rotate (arrow keys, Q/E) -->
    <KeyBinding Key="Left" Command="{Binding NudgeSelectedCommand}" CommandParameter="Left" />
    <KeyBinding Key="Right" Command="{Binding NudgeSelectedCommand}" CommandParameter="Right" />
    <KeyBinding Key="Up" Command="{Binding NudgeSelectedCommand}" CommandParameter="Forward" />
    <KeyBinding Key="Down" Command="{Binding NudgeSelectedCommand}" CommandParameter="Back" />
    <KeyBinding Key="Left" Modifiers="Shift" Command="{Binding NudgeSelectedCommand}" CommandParameter="LeftFine" />
    <KeyBinding Key="Right" Modifiers="Shift" Command="{Binding NudgeSelectedCommand}" CommandParameter="RightFine" />
    <KeyBinding Key="Up" Modifiers="Shift" Command="{Binding NudgeSelectedCommand}" CommandParameter="ForwardFine" />
    <KeyBinding Key="Down" Modifiers="Shift" Command="{Binding NudgeSelectedCommand}" CommandParameter="BackFine" />
    <KeyBinding Key="Q" Command="{Binding RotateSelectedCommand}" CommandParameter="Left" />
    <KeyBinding Key="E" Command="{Binding RotateSelectedCommand}" CommandParameter="Right" />
    <KeyBinding Key="Q" Modifiers="Shift" Command="{Binding RotateSelectedCommand}" CommandParameter="LeftFine" />
    <KeyBinding Key="E" Modifiers="Shift" Command="{Binding RotateSelectedCommand}" CommandParameter="RightFine" />

    <!-- View / camera -->
    <KeyBinding Key="Home" Command="{Binding ZoomExtentsAllNavigationCommand}" />
    <KeyBinding Key="F" Command="{Binding ZoomExtentsSelectionNavigationCommand}" />
    <KeyBinding Key="Decimal" Command="{Binding ZoomExtentsSelectionNavigationCommand}" />
    <KeyBinding Key="NumPad7" Command="{Binding StandardViewTopCommand}" />
    <KeyBinding Key="NumPad1" Command="{Binding StandardViewFrontCommand}" />
    <KeyBinding Key="NumPad3" Command="{Binding StandardViewRightCommand}" />
    <KeyBinding Key="NumPad0" Command="{Binding StandardViewHomePerspectiveCommand}" />

    <KeyBinding Key="Escape" Command="{Binding CancelViewportModesCommand}" />
    <KeyBinding Key="B" Command="{Binding StartBoxSelectModeCommand}" />
    <KeyBinding Key="C" Command="{Binding StartCircleSelectModeCommand}" />
    <KeyBinding Key="Divide" Command="{Binding ToggleIsolateSelectionCommand}" />
    <KeyBinding Key="Oem2" Command="{Binding ToggleIsolateSelectionCommand}" />
    <KeyBinding Key="X" Modifiers="Shift" Command="{Binding LockTranslateAxisXCommand}" />
    <KeyBinding Key="Z" Modifiers="Shift" Command="{Binding LockTranslateAxisZCommand}" />
  </Window.InputBindings>

  <Grid>
    <Grid.LayoutTransform>
      <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
    </Grid.LayoutTransform>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="28" />
    </Grid.RowDefinitions>

    <!-- Top menu (Blender-style clusters) -->
    <Menu Grid.Row="0" Background="{DynamicResource App.PanelBrush}">
      <MenuItem Header="_Datei">
        <MenuItem Header="_Neu…" InputGestureText="Strg+N" Command="{Binding NewLayoutCommand}" />
        <MenuItem Header="_Öffnen…" InputGestureText="Strg+O" Command="{Binding OpenLayoutCommand}" />
        <Separator />
        <MenuItem Header="_Speichern" InputGestureText="Strg+S" Command="{Binding SaveLayoutCommand}" />
        <MenuItem Header="Speichern _unter…" InputGestureText="Strg+Umschalt+S" Command="{Binding SaveLayoutAsCommand}" />
        <Separator />
        <MenuItem Header="_Import…" InputGestureText="Strg+Umschalt+I" Command="{Binding ImportModelAsyncCommand}" />
        <MenuItem Header="_Export… (JSON)" InputGestureText="Strg+Umschalt+E" Command="{Binding ExportLayoutJsonAsyncCommand}" />
        <Separator />
        <MenuItem Header="_Einstellungen…" InputGestureText="Strg+," Command="{Binding ShowPreferencesDialogCommand}" />
        <Separator />
        <MenuItem Header="_Beenden" InputGestureText="Strg+Q" Command="{Binding QuitApplicationCommand}" />
      </MenuItem>

      <MenuItem Header="_Bearbeiten">
        <MenuItem Header="_Rückgängig" InputGestureText="Strg+Z" Command="{Binding UndoCommand}" />
        <MenuItem Header="_Wiederholen" InputGestureText="Strg+Y" Command="{Binding RedoCommand}" />
        <Separator />
        <MenuItem Header="Auswahl _invertieren" InputGestureText="Strg+I" Command="{Binding InvertSelectionCommand}" />
        <MenuItem Header="Auswahl _aufheben" InputGestureText="Alt+A" Command="{Binding ClearSelectionMenuCommand}" />
        <MenuItem Header="_Alles auswählen / nichts" InputGestureText="A" Command="{Binding ToggleSelectAllPlacedCommand}" />
        <Separator />
        <MenuItem Header="_Duplizieren" InputGestureText="Strg+D / Umschalt+D" Command="{Binding DuplicateSelectedCommand}" />
        <MenuItem Header="_Löschen" InputGestureText="X / Entf" Command="{Binding DeleteSelectedCommand}" />
        <Separator />
        <MenuItem Header="_Ausblenden" InputGestureText="H" Command="{Binding HideSelectedPlacedCommand}" />
        <MenuItem Header="_Einblenden (alle)" InputGestureText="Alt+H" Command="{Binding ShowAllPlacedCommand}" />
        <Separator />
        <MenuItem Header="Local View / Isolate" InputGestureText="/" Command="{Binding ToggleIsolateSelectionCommand}" />
      </MenuItem>

      <MenuItem Header="_Modellierung">
        <MenuItem Header="Objekt aus Vorlage…" InputGestureText="Umschalt+A (später)" IsEnabled="False" />
        <MenuItem Header="_Löschen" Command="{Binding DeleteSelectedCommand}" />
      </MenuItem>

      <MenuItem Header="_Layout">
        <MenuItem Header="Workspace _Layout" Command="{Binding SetWorkspaceTabCommand}" CommandParameter="Layout" />
        <MenuItem Header="Workspace _Modeling" Command="{Binding SetWorkspaceTabCommand}" CommandParameter="Modeling" />
        <MenuItem Header="Workspace _Shading" IsEnabled="False" />
        <MenuItem Header="Workspace _Rendering" IsEnabled="False" />
      </MenuItem>

      <MenuItem Header="_Shading" IsEnabled="False" />
      <MenuItem Header="_Rendering" IsEnabled="False" />

      <MenuItem Header="_Ansicht">
        <MenuItem Header="Alles _einpassen" InputGestureText="Home" Command="{Binding ZoomExtentsAllNavigationCommand}" />
        <MenuItem Header="Auswahl _einpassen" InputGestureText="F / Num ." Command="{Binding ZoomExtentsSelectionNavigationCommand}" />
        <Separator />
        <MenuItem Header="Ansicht _Oben" InputGestureText="Num 7" Command="{Binding StandardViewTopCommand}" />
        <MenuItem Header="Ansicht _Vorne" InputGestureText="Num 1" Command="{Binding StandardViewFrontCommand}" />
        <MenuItem Header="Ansicht _Rechts" InputGestureText="Num 3" Command="{Binding StandardViewRightCommand}" />
        <MenuItem Header="Perspektive (_Home)" InputGestureText="Num 0" Command="{Binding StandardViewHomePerspectiveCommand}" />
      </MenuItem>
    </Menu>

    <!-- Workspace strip -->
    <Border Grid.Row="1"
            Background="{DynamicResource App.ElevatedBrush}"
            BorderBrush="{DynamicResource App.BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,6">
      <StackPanel Orientation="Horizontal">
        <TextBlock VerticalAlignment="Center"
                   Margin="0,0,12,0"
                   FontSize="11"
                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                   Text="Workspace" />
        <RadioButton Margin="0,0,10,0"
                     VerticalAlignment="Center"
                     GroupName="WsMain"
                     Content="Layout"
                     IsChecked="True"
                     Focusable="False"
                     Command="{Binding SetWorkspaceTabCommand}"
                     CommandParameter="Layout" />
        <RadioButton Margin="0,0,10,0"
                     VerticalAlignment="Center"
                     GroupName="WsMain"
                     Content="Modeling"
                     Focusable="False"
                     Command="{Binding SetWorkspaceTabCommand}"
                     CommandParameter="Modeling" />
        <RadioButton Margin="0,0,10,0"
                     VerticalAlignment="Center"
                     GroupName="WsMain"
                     Content="Shading"
                     IsEnabled="False" />
        <RadioButton VerticalAlignment="Center"
                     GroupName="WsMain"
                     Content="Rendering"
                     IsEnabled="False" />
      </StackPanel>
    </Border>

    <views:ToolbarView Grid.Row="2" />

    <Grid Grid.Row="3" Background="{DynamicResource App.BackgroundBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="280" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              BorderBrush="{DynamicResource App.BorderBrush}"
              BorderThickness="0,0,1,0">
        <TabControl Background="{DynamicResource App.PanelBrush}">
          <TabItem Header="Szene">
            <views:OutlinerPanel />
          </TabItem>
          <TabItem Header="Vorlagen">
            <views:AssetLibraryPanel />
          </TabItem>
        </TabControl>
      </Border>

      <Border Grid.Column="1"
              Background="{DynamicResource App.BackgroundBrush}">
        <views:ViewportPanel x:Name="MainViewport" />
      </Border>

      <Border Grid.Column="2"
              BorderBrush="{DynamicResource App.BorderBrush}"
              BorderThickness="1,0,0,0">
        <views:InspectorPanel />
      </Border>
    </Grid>

    <Border Grid.Row="4"
            Padding="10,4"
            Background="{DynamicResource App.ElevatedBrush}"
            BorderBrush="{DynamicResource App.BorderBrush}"
            BorderThickness="0,1,0,0">
      <TextBlock FontSize="11"
                 Foreground="{DynamicResource App.TextSecondaryBrush}"
                 Text="Timeline / Keyframes — für spätere Animationsphase reserviert" />
    </Border>

    <Border Grid.Row="5" Background="{DynamicResource App.PanelBrush}">
      <DockPanel LastChildFill="True" Margin="12,0">
        <TextBlock DockPanel.Dock="Right"
                   VerticalAlignment="Center"
                   Margin="12,0,0,0"
                   FontSize="12"
                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                   Text="{Binding ModeLabel}" />

        <TextBlock VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{DynamicResource App.TextSecondaryBrush}"
                   Text="{Binding StatusText}" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
